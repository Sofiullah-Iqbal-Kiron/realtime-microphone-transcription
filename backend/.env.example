# Environment
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/transcription_db
DEBUG=false
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-real-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_LIFETIME=86400
REFRESH_TOKEN_LIFETIME=604800

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM_NAME=Transcription App
EMAIL_TOKEN_EXPIRY=3600

# Whisper model config
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Audio
AUDIO_SAMPLE_RATE=16000
TRANSCRIPTION_INTERVAL_SECONDS=1.0
